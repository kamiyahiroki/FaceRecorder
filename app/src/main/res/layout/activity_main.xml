<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Camera band: resized in code to a centered 4:3 landscape strip so that the
         preview shows exactly the 640×480 region that gets recorded (the rest of the
         portrait screen stays black). Both the preview and the guide live inside it. -->
    <FrameLayout
        android:id="@+id/cameraBand"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center">

        <!-- Camera preview: always visible behind panels -->
        <androidx.camera.view.PreviewView
            android:id="@+id/previewView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:scaleType="fillCenter" />

        <!-- Face position guide: darkens outside the head oval during recording.
             Mirrors _draw_face_guide() in recorder.py. Always drawn; panelInput's
             opaque background hides it during the name-entry screen. -->
        <com.example.facerecorder.FaceGuideView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clickable="false"
            android:focusable="false" />

    </FrameLayout>

    <!-- Input panel: shown at startup -->
    <LinearLayout
        android:id="@+id/panelInput"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#CC000000"
        android:padding="40dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="顔登録録画ツール"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="名前を入力"
            android:inputType="textPersonName"
            android:singleLine="true"
            android:background="#FFFFFF"
            android:padding="14dp"
            android:textSize="16sp"
            android:textColor="#000000"
            android:textColorHint="#AAAAAA"
            android:layout_marginBottom="20dp" />

        <Button
            android:id="@+id/btnStart"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="録画開始"
            android:textSize="18sp" />

    </LinearLayout>

    <!-- Recording overlay: shown during wizard sequence -->
    <FrameLayout
        android:id="@+id/panelRecording"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <!-- Top bar: pose progress + instruction -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#CC000000"
            android:padding="16dp"
            android:layout_gravity="top">

            <TextView
                android:id="@+id/tvPoseProgress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#AAAAAA"
                android:textSize="14sp"
                android:text="[1/5]" />

            <TextView
                android:id="@+id/tvInstruction"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp"
                android:text="正面を向いてください" />

        </LinearLayout>

        <!-- Center: countdown number or recording indicator -->
        <TextView
            android:id="@+id/tvCountdown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:textColor="#FFFFFF"
            android:textSize="96sp"
            android:textStyle="bold"
            android:shadowColor="#000000"
            android:shadowDx="2"
            android:shadowDy="2"
            android:shadowRadius="6"
            android:text="3" />

        <!-- Bottom: angle status text + progress bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_gravity="bottom">

            <TextView
                android:id="@+id/tvAngleStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:background="#CC000000"
                android:text="" />

            <ProgressBar
                android:id="@+id/progressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="10dp"
                android:max="100"
                android:progress="0"
                android:progressTint="#FF4444"
                android:progressBackgroundTint="#555555" />

        </LinearLayout>

    </FrameLayout>

    <!-- Completion panel: shown after all poses recorded -->
    <LinearLayout
        android:id="@+id/panelComplete"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#CC000000"
        android:padding="40dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="録画完了！"
            android:textColor="#00FF88"
            android:textSize="32sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="保存先:"
            android:textColor="#AAAAAA"
            android:textSize="13sp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvFilePath"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:gravity="center"
            android:layout_marginBottom="40dp" />

        <Button
            android:id="@+id/btnClose"
            android:layout_width="200dp"
            android:layout_height="56dp"
            android:text="閉じる"
            android:textSize="16sp" />

    </LinearLayout>

</FrameLayout>
